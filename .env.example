# Cockpit 配置文件示例
# 复制为 .env 并填入实际值

# ===== 应用配置 =====
# 环境：development | production | test
COCKPIT_ENV=development
# 数据目录（默认 ~/.cockpit，首次启动时自动从 ~/.shiguang 迁移老数据）
COCKPIT_DATA_DIR=~/.cockpit
COCKPIT_PORT=7842
COCKPIT_HOST=127.0.0.1

# ===== LLM 配置 =====
# LLM 后端：anthropic | deepseek | minimax | openai | custom
# 也可以通过 Web UI (设置页) 运行时配置，DB 优先于 .env
COCKPIT_LLM_BACKEND=anthropic
COCKPIT_LLM_MODEL=claude-sonnet-4-5

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- DeepSeek ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- MiniMax (MiniMax 官方 OpenAI 兼容 API) ---
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=abab6.5s-chat

# --- OpenAI 兼容（用户自定义 endpoint）---
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# ===== 数据存储 =====
# 单机版用 SQLite，云端版用 PostgreSQL
# 留空则使用默认路径：${COCKPIT_DATA_DIR}/cockpit.db
DATABASE_URL=

# ===== 安全 =====
# 用于本地数据加密的密钥（用 `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"` 生成）
COCKPIT_ENCRYPTION_KEY=

# ===== 同步（v1.1，暂未实现） =====
COCKPIT_SYNC_ENABLED=false
COCKPIT_SYNC_PROVIDER=icloud  # icloud | custom

# ===== 通知（v1.1，暂未实现） =====
# 飞书机器人
FEISHU_WEBHOOK_URL=
# 系统通知
COCKPIT_SYSTEM_NOTIFICATION=true
