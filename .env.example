# 拾光配置文件示例
# 复制为 .env 并填入实际值

# ===== 应用配置 =====
SHIGUANG_ENV=development
SHIGUANG_DATA_DIR=~/.shiguang
SHIGUANG_PORT=7842
SHIGUANG_HOST=127.0.0.1

# ===== LLM 配置 =====
# LLM 后端：anthropic | ollama | openai
SHIGUANG_LLM_BACKEND=anthropic
SHIGUANG_LLM_MODEL=claude-sonnet-4-5

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Ollama（本地降级）
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:14b

# OpenAI 兼容（用户自定义 endpoint）
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# ===== 数据存储 =====
# 单机版使用 SQLite，云端版用 PostgreSQL
DATABASE_URL=sqlite:///./shiguang.db

# ===== 安全 =====
# 用于本地数据加密的密钥（用 `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"` 生成）
SHIGUANG_ENCRYPTION_KEY=

# ===== 同步（v1.1） =====
SHIGUANG_SYNC_ENABLED=false
SHIGUANG_SYNC_PROVIDER=icloud  # icloud | custom

# ===== 通知（v1.1） =====
# 飞书机器人
FEISHU_WEBHOOK_URL=
# 系统通知
SHIGUANG_SYSTEM_NOTIFICATION=true
