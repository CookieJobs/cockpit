# Cockpit 生产环境配置 (deploy/.env.production)
# 用法: cp .env.production.example .env.production, 然后填真实值
#
# 注意: 此文件**不会被** git 跟踪 (.gitignore 已加 deploy/data/ 但 .env.production 本身要靠 docker-compose 读)
# 实际只忽略 deploy/data/，不忽略 .env.production 文本
# 但建议在 .gitignore 单独加 deploy/.env.production (部署专用, 不入库)
#
# ==== 必填 (至少一个 LLM API key, 否则聊天走关键词 fallback) ====

# Anthropic Claude (默认后端, 主力 LLM)
ANTHROPIC_API_KEY=sk-ant-xxx

# DeepSeek (备选, 便宜)
# DEEPSEEK_API_KEY=sk-xxx

# OpenAI 兼容 (自定义服务, 比如本地 ollama / 第三方)
# OPENAI_API_KEY=xxx
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3

# MiniMax
# MINIMAX_API_KEY=xxx

# ==== 可选: 后端选择 ====

# 用哪个 LLM 后端: anthropic | deepseek | openai | minimax | custom
COCKPIT_LLM_BACKEND=anthropic

# 模型名 (跟后端匹配)
COCKPIT_LLM_MODEL=claude-sonnet-4-5

# ==== 可选: CORS 白名单 ====
# 默认只允许前端同源 (因为同源 fetch 不触发 CORS), 不需要改
# 除非加了 nginx/反代 把前端/后端分到不同 origin
# 多个 origin 用英文逗号分隔
# COCKPIT_CORS_ORIGINS=http://62.234.180.241,https://cockpit.example.com

# ==== 可选: 自定义后端 base URL (如用代理) ====
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# ==== 安全 (可选, 加密 LLM settings 里存的 API key) ====
# 32 字节随机字符串 (python -c "import secrets; print(secrets.token_urlsafe(32))")
# COCKPIT_ENCRYPTION_KEY=

# ==== 数据库 (可选, 默认 SQLite 走 COCKPIT_DATA_DIR/cockpit.db) ====
# 想用别的 DB: DATABASE_URL=postgresql+asyncpg://user:pass@host/db
# DATABASE_URL=
